# ============================================
#  ASCENTIUM DASHBOARD - BACKEND ENVIRONMENT
# ============================================
# Copy this file to `.env` and fill in real values.
#  cp .env.example .env

# --------- SERVER ---------
NODE_ENV=development
PORT=5000
# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --------- DATABASE (MongoDB) ---------
# Local Mongo:   mongodb://127.0.0.1:27017/ascentium
# Atlas cloud:   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/ascentium
MONGO_URI=mongodb://127.0.0.1:27017/ascentium

# --------- AUTH (JWT) ---------
# Generate a strong random secret: `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=replace_me_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# --------- SEED SUPER ADMIN ---------
# Used once on `npm run seed` to create the first super admin
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@ascentium.local
SEED_ADMIN_PASSWORD=ChangeMe@123

# --------- CRON / AUTOMATION ---------
# Default: 7 AM India Standard Time (Asia/Kolkata).  IST = UTC+5:30.
# Cron format: "minute hour day-of-month month day-of-week"
CRON_SCHEDULE=0 7 * * *
CRON_TIMEZONE=Asia/Kolkata
# Set ENABLE_CRON=false to disable scheduled fetching (useful in dev)
ENABLE_CRON=true

# --------- N8N INTEGRATION (Optional, for Admin -> n8n run) ---------
# Production webhook URL from n8n. Use the production URL after publishing/activating the workflow.
N8N_WEBHOOK_URL_NEWS=
N8N_WEBHOOK_URL_GOVT=
N8N_WEBHOOK_URL_COMPETITOR=
N8N_WEBHOOK_URL_EVERGREEN=
# Public backend callback endpoint that n8n can reach.
# Example: https://api.yourdomain.com/api/n8n/log
N8N_CALLBACK_URL=
# Same value must be sent back by n8n in the x-n8n-secret header.
N8N_CALLBACK_SECRET=
# Optional secret sent from backend to n8n webhook, if your n8n webhook validates it.
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_TIMEOUT_MS=1200000

# --------- SCRAPING ---------
# Request timeout in milliseconds
SCRAPE_TIMEOUT_MS=20000
# How many concurrent scraping requests at once
SCRAPE_CONCURRENCY=4
# User-Agent used in HTTP requests
SCRAPE_USER_AGENT=Mozilla/5.0 (compatible; AscentiumIntelBot/1.0)

# --------- TAVILY (Optional, for relevance + evergreen) ---------
# Get a free key from https://tavily.com  -> leave empty to skip Tavily
TAVILY_API_KEY= 

# --------- OPENAI (Optional, for AI summary + smart category) ---------
# Get a key from https://platform.openai.com -> leave empty to use rule-based fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Use AI for summary generation? (true/false)
OPENAI_USE_FOR_SUMMARY=false
# Use AI for category classification? (true/false)
OPENAI_USE_FOR_CATEGORY=false
