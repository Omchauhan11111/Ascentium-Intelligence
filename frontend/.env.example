# Frontend env (Vite). Keys MUST start with VITE_ to be exposed to the browser.
# Copy this file to `.env` and adjust if needed.
#  cp .env.example .env

# Base URL of the backend API. In dev, leave blank to use the Vite proxy.
VITE_API_BASE_URL=

# Optional: where the Vite proxy forwards /api requests to (default http://localhost:5000)
VITE_API_PROXY=http://localhost:5000
